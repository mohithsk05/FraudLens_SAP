# ====================================================================
#              FRAUDLENS SECURITY GATEWAY CONFIGURATIONS
# ====================================================================

# 1. REAL-TIME TELEGRAM PUSH NOTIFICATION CHANNELS
# Create a bot via @BotFather in Telegram and retrieve the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Message @userinfobot in Telegram to retrieve your Chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 2. REAL-TIME TWILIO SMS HELPLINE GATEWAYS
# Create a developer sandbox at twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+919876543210

# 3. PRODUCTION DATABASES (FALLBACKS TO SQLITE LOCAL BY DEFAULT)
# Uncomment to hook to a persistent enterprise PostgreSQL cluster (e.g. Supabase)
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
